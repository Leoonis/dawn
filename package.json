{
  "name": "noctorya-dawn",
  "version": "1.0.0",
  "description": "Noctorya Shopify Dawn fork theme",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "format": "prettier --write '**/*.{liquid,css,js,json}'",
    "format:check": "prettier --check '**/*.{liquid,css,js,json}'",
    "theme:check": "shopify theme check --fail-level=error"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leoonis/dawn.git"
  },
  "devDependencies": {
    "@shopify/prettier-plugin-liquid": "^1.10.2",
    "prettier": "^3.8.3"
  }
}
