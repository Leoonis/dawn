{%- comment -%}
  Section: main-links
  Purpose: ultra-light bio-link page for /links route. Lands social traffic
  (@noctorya IG + TikTok + @chiarivista sister) on a Noctorya-branded page
  in <2s LCP on throttled 3G.

  WHY system fonts + inline CSS (no asset_url stylesheet_tag, no @font-face):
  per CLAUDE.md "/links page exception" — zero external CSS request, zero
  WOFF2 download on critical path. Brand fidelity preserved via system serif
  (Georgia/Didot/Bodoni MT) fallback chain that approximates Bodoni Moda.

  WHY hex literals not Dawn token vars: brand-tokens.css still loads from
  layout/theme.liquid, but inline hex frees the section's first paint from
  any cascade dependency. Hex values are the canonical brand values.
{%- endcomment -%}

<style>
  .main-links {
    background-color: #111111;
    color: #F0F0F0;
    min-height: 100vh;
    padding: 64px 20px;
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  .main-links__container {
    max-width: 480px;
    margin: 0 auto;
  }
  .main-links__header {
    text-align: center;
    margin-bottom: 48px;
  }
  .main-links__heading {
    font-family: Georgia, "Bodoni MT", Didot, "Times New Roman", serif;
    font-size: 36px;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: 0.02em;
    margin: 0 0 12px;
    color: #F0F0F0;
  }
  .main-links__subheading {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #B0B0B0;
    margin: 0;
  }
  .main-links__nav {
    margin: 0;
  }
  .main-links__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .main-links__item {
    margin: 0;
  }
  .main-links__link {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 14px 20px;
    background-color: #181818;
    border: 1px solid #2A2A2A;
    color: #F0F0F0;
    text-decoration: none;
    text-align: center;
    transition: background-color 160ms ease, border-color 160ms ease;
  }
  .main-links__link:hover {
    background-color: #1F1F1F;
    border-color: #3A3A3A;
  }
  .main-links__link:focus-visible {
    background-color: #1F1F1F;
    border-color: #3A3A3A;
    outline: 2px solid #A8A8A8;
    outline-offset: 2px;
    box-shadow: 0 0 0 1px #A8A8A8;
  }
  .main-links__link-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .main-links__link-secondary {
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: #B0B0B0;
    margin-top: 6px;
    text-transform: none;
  }
  .main-links__empty {
    text-align: center;
    color: #838383;
    font-size: 13px;
    letter-spacing: 0.04em;
  }

  @media (min-width: 750px) {
    .main-links {
      padding: 96px 20px;
    }
    .main-links__heading {
      font-size: 48px;
    }
    .main-links__header {
      margin-bottom: 56px;
    }
  }
</style>

<section class="main-links" aria-labelledby="main-links-heading">
  <div class="main-links__container">
    <header class="main-links__header">
      <h1 id="main-links-heading" class="main-links__heading">
        {{ section.settings.heading_text | escape }}
      </h1>
      {%- if section.settings.subheading_text != blank -%}
        <p class="main-links__subheading">
          {{ section.settings.subheading_text | escape }}
        </p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <nav class="main-links__nav" aria-label="Noctorya links">
        <ul class="main-links__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'link' -%}
              {%- assign link_label = block.settings.link_label | strip -%}
              {%- assign link_url = block.settings.link_url -%}
              {%- assign link_secondary = block.settings.link_secondary_text | strip -%}
              {%- if link_label != blank and link_url != blank -%}
                {%- comment -%}
                  External-link detection: any URL that does not start with "/"
                  is treated as external and receives rel="noopener noreferrer"
                  as a baseline security hygiene measure. No target=_blank by
                  default; social-bio traffic prefers same-tab navigation.
                {%- endcomment -%}
                {%- assign is_external = true -%}
                {%- if link_url startswith '/' -%}
                  {%- assign is_external = false -%}
                {%- endif -%}
                <li class="main-links__item" {{ block.shopify_attributes }}>
                  <a
                    class="main-links__link"
                    href="{{ link_url }}"
                    {%- if is_external %} rel="noopener noreferrer"{% endif -%}
                  >
                    <span class="main-links__link-label">{{ link_label | escape }}</span>
                    {%- if link_secondary != blank -%}
                      <span class="main-links__link-secondary">{{ link_secondary | escape }}</span>
                    {%- endif -%}
                  </a>
                </li>
              {%- endif -%}
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>
    {%- else -%}
      <p class="main-links__empty">No links configured.</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Links page",
  "tag": "section",
  "class": "section-main-links",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Heading",
      "default": "Noctorya"
    },
    {
      "type": "text",
      "id": "subheading_text",
      "label": "Subheading",
      "default": "The Minimal Black Gallery"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "link_label",
          "label": "Label",
          "info": "Uppercase rendered automatically. Keep short."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Destination URL"
        },
        {
          "type": "text",
          "id": "link_secondary_text",
          "label": "Secondary text (optional)",
          "info": "Small caption shown below the label."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Links page",
      "blocks": [
        { "type": "link" },
        { "type": "link" },
        { "type": "link" },
        { "type": "link" }
      ]
    }
  ]
}
{% endschema %}
