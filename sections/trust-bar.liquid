{{ 'trust-bar.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign pad = section.settings.padding_vertical
  assign cw = section.settings.container_width
-%}

<section
  class="trust-bar"
  style="--trust-bar-padding: {{ pad }}px;"
  aria-label="Trust signals"
>
  <div class="trust-bar__container trust-bar__container--{{ cw }}">
    <div class="trust-bar__list">
      {%- for block in section.blocks -%}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          <span class="trust-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                  <path d="M15 18H9"/>
                  <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
                  <circle cx="17" cy="18" r="2"/>
                  <circle cx="7" cy="18" r="2"/>
                </svg>
              {%- when 'printer' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 6 2 18 2 18 9"/>
                  <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
                  <rect width="12" height="8" x="6" y="14"/>
                </svg>
              {%- when 'undo' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M9 14 4 9l5-5"/>
                  <path d="M4 9h10.5a5.5 5.5 0 0 1 5.5 5.5a5.5 5.5 0 0 1-5.5 5.5H11"/>
                </svg>
              {%- when 'lock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
            {%- endcase -%}
          </span>
          <span class="trust-bar__label">{{ block.settings.text }}</span>
        </div>
        {%- unless forloop.last -%}
          <span class="trust-bar__separator" aria-hidden="true">&middot;</span>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "Vertical padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container width",
      "options": [
        { "value": "default", "label": "Default (1280px)" },
        { "value": "wide", "label": "Wide (1500px)" },
        { "value": "full", "label": "Full bleed" }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "printer", "label": "Printer (quality)" },
            { "value": "undo", "label": "Undo arrow (returns)" },
            { "value": "lock", "label": "Lock (security)" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "FREE POSTER SHIPPING"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "badge", "settings": { "icon": "truck", "text": "FREE POSTER SHIPPING" } },
        { "type": "badge", "settings": { "icon": "printer", "text": "MUSEUM-QUALITY PRINTING" } },
        { "type": "badge", "settings": { "icon": "undo", "text": "30-DAY RETURNS" } },
        { "type": "badge", "settings": { "icon": "lock", "text": "SECURE CHECKOUT" } }
      ]
    }
  ]
}
{% endschema %}
