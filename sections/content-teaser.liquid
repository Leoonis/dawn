{{ 'content-teaser.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign featured_product = section.settings.product
  assign featured_blog = section.settings.blog_post
  assign excerpt = section.settings.excerpt
-%}

{%- if featured_product != blank and featured_blog != blank -%}
<section class="content-teaser" aria-label="Featured story">
  <div class="content-teaser__container">
    <h2 class="content-teaser__heading">THE STORIES</h2>
    <div class="content-teaser__row">
      <a href="{{ featured_product.url }}" class="content-teaser__image-link" aria-label="View {{ featured_product.title | escape }}">
        <img
          class="content-teaser__image"
          src="{{ featured_product.featured_image | image_url: width: 1200 }}"
          alt="{{ featured_product.featured_image.alt | default: featured_product.title | escape }}"
          loading="lazy"
          width="{{ featured_product.featured_image.width }}"
          height="{{ featured_product.featured_image.height }}"
        >
      </a>
      <div class="content-teaser__text">
        <p class="content-teaser__excerpt">{{ excerpt }}</p>
        <a href="{{ featured_blog.url }}" class="content-teaser__cta">
          Read the Story &rarr;
        </a>
      </div>
    </div>
  </div>
</section>
{%- endif -%}

{% schema %}
{
  "name": "Content Teaser",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Featured painting"
    },
    {
      "type": "blog",
      "id": "blog_post",
      "label": "Featured blog post"
    },
    {
      "type": "textarea",
      "id": "excerpt",
      "label": "Excerpt (1-2 sentences from blog post)"
    }
  ],
  "presets": [
    {
      "name": "Content Teaser"
    }
  ]
}
{% endschema %}
